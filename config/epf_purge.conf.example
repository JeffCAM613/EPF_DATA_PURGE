# ============================================================================
# EPF Data Purge - Configuration File
# ============================================================================
# Copy this file to epf_purge.conf and edit the values.
# Used for automated/scheduled runs (non-interactive mode).
#
# Usage:
#   Linux:   ./bin/epf_purge.sh --config config/epf_purge.conf
#   Windows: bin\epf_purge.bat --config config\epf_purge.conf
# ============================================================================

# Oracle connection
TNS_NAME=EPFPROD
USERNAME=oppayments

# Password: For security, set via environment variable EPF_PURGE_PASSWORD
# instead of storing it here. If EPF_PURGE_PASSWORD is set, it takes
# precedence over this value.
# PASSWORD=

# Purge parameters
RETENTION_DAYS=30
PURGE_DEPTH=ALL
BATCH_SIZE=1000

# Execution options
DRY_RUN=N
RECLAIM_SPACE=N
RECLAIM_ONLINE=N
SKIP_STALL_CHECKS=N
DROP_PACKAGE_AFTER=N

# Reclaim squeeze iteration cap. Leave empty to let the wrapper recommend
# based on tablespace datafile size: max(2000, 50 * datafile_gb), capped 20000.
# Override with a fixed value if you want a tight cap.
# MAX_ITERATIONS=
