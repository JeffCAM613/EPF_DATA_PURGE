-- STEP 1: Add larger redo log groups (run as SYSDBA)
-- ============================================================
-- Check current state
SELECT group#, bytes/1024/1024 AS size_mb, status, members FROM v$log;
--ALTER DATABASE DATAFILE '/files2/oradata19/EPFPG781/undotbs01.dbf' RESIZE 1G
--Error report -
--ORA-03297: file contains used data beyond requested RESIZE value
--
--https://docs.oracle.com/error-help/db/ora-03297/03297. 00000 -  "File contains used data beyond requested RESIZE value."
--*Cause:    Some portion of the file in the region to be trimmed was
--           currently in use by one or more database objects.
--*Action:   Drop or move segments containing extents in this region prior to
--           resizing the file, or choose a RESIZE value limited to free
--           space in the tail of the file being trimmed.
SELECT group#, member FROM v$logfile ORDER BY group#;
--1	/files2/oradata19/EPFPG788/G1_1.log
--2	/files2/oradata19/EPFPG788/G2_1.log
--3	/files2/oradata19/EPFPG788/G3_1.log

-- Replace the path below with what v$logfile returns
-- Example if it shows: /u01/app/oracle/oradata/DBNAME/redo01.log -- need to get path dynamically
ALTER DATABASE ADD LOGFILE GROUP 4 ('/files2/oradata19/EPFPG788/G4_1.log') SIZE 1G;
ALTER DATABASE ADD LOGFILE GROUP 5 ('/files2/oradata19/EPFPG788/G5_1.log') SIZE 1G;
ALTER DATABASE ADD LOGFILE GROUP 6 ('/files2/oradata19/EPFPG788/G6_1.log') SIZE 1G;
ALTER DATABASE ADD LOGFILE GROUP 7 ('/files2/oradata19/EPFPG788/G7_1.log') SIZE 1G;

-- Force Oracle to rotate into the new groups
ALTER SYSTEM SWITCH LOGFILE;
ALTER SYSTEM SWITCH LOGFILE;
ALTER SYSTEM SWITCH LOGFILE;
ALTER SYSTEM SWITCH LOGFILE;

-- Wait a few seconds for checkpoints, then verify old groups are INACTIVE
SELECT group#, bytes/1024/1024 AS size_mb, status FROM v$log;
--1	150	ACTIVE
--2	150	INACTIVE
--3	150	INACTIVE
--4	1024	ACTIVE
--5	1024	ACTIVE
--6	1024	ACTIVE
--7	1024	CURRENT

-- Drop old small groups (only if status = INACTIVE, never CURRENT)
ALTER DATABASE DROP LOGFILE GROUP 1;
ALTER DATABASE DROP LOGFILE GROUP 2;
ALTER DATABASE DROP LOGFILE GROUP 3;
-- If any says "ORA-01623: log group is current" just SWITCH LOGFILE again and retry

ALTER SYSTEM CHECKPOINT;

-- Verify all old groups are now INACTIVE
SELECT group#, bytes/1024/1024 AS size_mb, status FROM v$log;
--4	1024	INACTIVE
--5	1024	INACTIVE
--6	1024	INACTIVE
--7	1024	CURRENT

-- Then drop them
ALTER DATABASE DROP LOGFILE GROUP 1;
ALTER DATABASE DROP LOGFILE GROUP 2;
ALTER DATABASE DROP LOGFILE GROUP 3;



