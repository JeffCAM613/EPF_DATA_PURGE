-- Stop the Data Pump job gracefully
-- First find the job name
SELECT owner_name, job_name, state FROM dba_datapump_jobs WHERE state = 'EXECUTING';
--SYSTEM	SYS_IMPORT_SCHEMA_01	EXECUTING
-- Attach and kill it
-- From a separate sqlplus session as the import user:
-- impdp system/password@EPFPG788 attach=<job_name>
-- Then at the Import> prompt: KILL_JOB

-- Or just kill the sessions directly
ALTER SYSTEM KILL SESSION '133,41867' IMMEDIATE;  -- Worker
ALTER SYSTEM KILL SESSION '870,61633' IMMEDIATE;  -- Master














-- Find sessions locking the package
SELECT s.sid, s.serial#, s.username, s.program, s.status,
       s.sql_id, s.last_call_et AS idle_secs
FROM v$locked_object lo
JOIN dba_objects o ON lo.object_id = o.object_id
JOIN v$session s ON lo.session_id = s.sid
WHERE o.object_name = 'EPF_PURGE_PKG';

-- Find any session referencing OPPAYMENTS objects
SELECT sid, serial#, username, program, status, last_call_et
FROM v$session
WHERE username = 'OPPAYMENTS'
  AND sid != SYS_CONTEXT('USERENV', 'SID');
  
ALTER SYSTEM KILL SESSION 'sid,serial#' IMMEDIATE;



-- Run as SYS/SYSDBA on the instance
