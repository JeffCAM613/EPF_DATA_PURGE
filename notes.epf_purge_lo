-- Find who is blocking whom
SELECT s1.sid AS blocked_sid, s1.username AS blocked_user,
       s2.sid AS blocker_sid, s2.username AS blocker_user,
       s2.status AS blocker_status, s2.event AS blocker_event,
       s2.sql_id AS blocker_sql
FROM v$session s1
JOIN v$session s2 ON s1.blocking_session = s2.sid
WHERE s1.blocking_session IS NOT NULL;
--133	SYSTEM	753	OPPAYMENTS	ACTIVE	db file scattered read	f4j1jbg41qju7

-- Check for dead/killed sessions still rolling back
SELECT sid, serial#, status, username, event,
       ROUND(last_call_et/60) AS minutes_ago
FROM v$session
WHERE status = 'KILLED'
   OR (username = 'OPPAYMENTS' AND event LIKE '%undo%');
   --norows

-- Check SMON rollback progress
SELECT usn, state, undoblockstotal, undoblocksdone,
       CASE WHEN undoblockstotal > 0
            THEN ROUND(undoblocksdone/undoblockstotal*100, 1)
            ELSE 0 END AS pct_done
FROM v$transaction
WHERE status = 'ACTIVE';
