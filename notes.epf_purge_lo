-- Step 1: Try the simple resize first (now that the overflow is fixed)
ALTER DATABASE DATAFILE '/files2/oradata19/EPFPG781/undotbs01.dbf' RESIZE 1G;
--Error starting at line : 93 in command -
--ALTER DATABASE DATAFILE '/files2/oradata19/EPFPG781/undotbs01.dbf' RESIZE 1G
--Error report -
--ORA-03297: file contains used data beyond requested RESIZE value
--
--https://docs.oracle.com/error-help/db/ora-03297/03297. 00000 -  "File contains used data beyond requested RESIZE value."
--*Cause:    Some portion of the file in the region to be trimmed was
--           currently in use by one or more database objects.
--*Action:   Drop or move segments containing extents in this region prior to
--           resizing the file, or choose a RESIZE value limited to free
--           space in the tail of the file being trimmed.

-- Step 2: Nuclear option - swap undo tablespace
-- Create a new 1 GB undo tablespace
CREATE UNDO TABLESPACE UNDOTBS2
    DATAFILE '/files2/oradata19/EPFPG781/undotbs02.dbf' SIZE 1G
    AUTOEXTEND ON NEXT 256M MAXSIZE 8G;

-- Switch to the new one (all new transactions use it)
ALTER SYSTEM SET undo_tablespace = UNDOTBS2;

-- Wait a few seconds for in-flight transactions to finish, then drop the old one
-- (If any active txns remain, Oracle will wait for them)
DROP TABLESPACE UNDOTBS1 INCLUDING CONTENTS AND DATAFILES;







